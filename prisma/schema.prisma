/**
 * ⚙️ CONFIG
 */
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

////////////////////////////////////////////////////////
//////////////////// 👤 USERS ///////////////////////////
////////////////////////////////////////////////////////

/**
 * 👤 Usuário do sistema (admin/social media)
 */
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  createdAt DateTime @default(now())

  /**
   * 🔗 Um usuário pode ter vários clientes
   */
  clients Client[]
}

////////////////////////////////////////////////////////
//////////////////// 👥 CLIENTS /////////////////////////
////////////////////////////////////////////////////////

/**
 * 👥 Restaurante / Cliente
 */
model Client {
  id        String   @id @default(uuid())
  name      String
  logo      String?
  createdAt DateTime @default(now())

  /**
   * 🔗 Relação com usuário
   */
  userId String
  user   User   @relation(fields: [userId], references: [id])

  /**
   * 🔗 Relação com posts
   */
  posts Post[]
}

////////////////////////////////////////////////////////
//////////////////// 📝 POSTS ///////////////////////////
////////////////////////////////////////////////////////

/**
 * 📝 Post de rede social
 */
model Post {
  id          String     @id @default(uuid())
  title       String?
  caption     String
  image       String?
  status      PostStatus @default(IDEA)
  scheduledAt DateTime?
  createdAt   DateTime   @default(now())

  /**
   * 🔗 Relação com cliente
   */
  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  /**
   * 🔗 Comentários
   */
  comments Comment[]

  /**
   * 🔗 Aprovações
   */
  approvals Approval[]
}

////////////////////////////////////////////////////////
//////////////////// 💬 COMMENTS ////////////////////////
////////////////////////////////////////////////////////

/**
 * 💬 Comentários do cliente no post
 */
model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())

  /**
   * 🔗 Relação com post
   */
  postId String
  post   Post   @relation(fields: [postId], references: [id])
}

////////////////////////////////////////////////////////
//////////////////// ✅ APPROVALS ///////////////////////
////////////////////////////////////////////////////////

/**
 * ✅ Controle de aprovação
 */
model Approval {
  id        String         @id @default(uuid())
  status    ApprovalStatus
  createdAt DateTime       @default(now())

  /**
   * 🔗 Relação com post
   */
  postId String
  post   Post   @relation(fields: [postId], references: [id])
}

////////////////////////////////////////////////////////
//////////////////// ENUMS //////////////////////////////
////////////////////////////////////////////////////////

/**
 * 🚦 Status do post
 */
enum PostStatus {
  IDEA
  CREATING
  PENDING
  APPROVED
}

/**
 * ✅ Status de aprovação
 */
enum ApprovalStatus {
  APPROVED
  CHANGES_REQUESTED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String   // 🔐 obrigatório agora
  createdAt DateTime @default(now())

  clients   Client[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  createdAt DateTime @default(now())
}
